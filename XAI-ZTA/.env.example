# XAI-ZTA Configuration
# Copy this file to .env and fill in values

# Data paths
RAW_DATA_PATH=data/raw/
PROCESSED_DATA_PATH=data/processed/
SYNTHETIC_DATA_PATH=data/synthetic/

# Model configuration
MODEL_SAVE_PATH=experiments/results/
RANDOM_SEED=42

# Dashboard
STREAMLIT_PORT=8501
DASHBOARD_TITLE=XAI-ZTA Authentication Monitor

# Logging
LOG_LEVEL=INFO
LOG_PATH=experiments/logs/

# ZTA Policy
TRUST_THRESHOLD=0.65
REAUTH_INTERVAL_MINUTES=15
